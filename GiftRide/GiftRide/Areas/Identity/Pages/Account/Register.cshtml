@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    :root {
        --gift-teal: #2dd4bf;
        --ride-orange: #f43f5e;
        --ride-yellow: #fbbf24;
        --gift-blue: #0ea5e9;
    }

    
    body {
        font-family: 'Montserrat', sans-serif;
        background-color: #f8fafc;     
        background-image: radial-gradient(at 0% 0%, rgba(45, 212, 191, 0.15) 0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.15) 0px, transparent 50%); 
        background-attachment: fixed; 
        background-size: cover;
    }

  
    .card-registration {
        border: none;
        border-radius: 24px;
        background: #ffffff;        
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        position: relative;
    }

      
        .card-registration::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(to right, var(--gift-teal), var(--ride-orange));
        }

    .brand-logo {
        font-weight: 800;
        font-size: 2.2rem;
        color: var(--gift-teal);
        text-align: center;
        margin-bottom: 5px;
        display: block;
        text-decoration: none;
        letter-spacing: -1px;
    }

        .brand-logo span {
            color: var(--ride-orange);
        }

    .form-floating > .form-control {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        background-color: #fcfcfc;
        padding-right: 45px;
        transition: all 0.2s ease;
    }

        .form-floating > .form-control:focus {
            border-color: var(--gift-teal);
            box-shadow: 0 0 0 4px rgba(45, 212, 191, 0.1);
            background-color: white;
            transform: translateY(-1px);
        }

    .form-floating > label {
        color: #94a3b8;
        font-weight: 500;
    }

   
    .btn-register {
        background: linear-gradient(135deg, var(--ride-orange), #f97316);
        border: none;
        color: white;
        font-weight: 700;
        padding: 16px;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        box-shadow: 0 10px 25px rgba(244, 63, 94, 0.25);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 35px rgba(244, 63, 94, 0.4);
            color: white;
            background: linear-gradient(135deg, #f97316, var(--ride-orange));
        }

    .login-link {
        color: var(--gift-teal);
        font-weight: 700;
        transition: color 0.2s;
    }

        .login-link:hover {
            color: var(--ride-orange);
        }

    .input-icon {
        position: absolute;
        right: 18px;
        top: 20px;
        color: #cbd5e1;
        font-size: 1.2rem;
        z-index: 10;
        pointer-events: none;
        transition: color 0.2s;
    }

   
    .form-floating > .form-control:focus ~ .input-icon {
        color: var(--gift-teal);
    }

    .text-danger {
        font-size: 0.8rem;
        margin-left: 5px;
        margin-top: 4px;
        font-weight: 500;
    }

    
    .fade-in-up {
        animation: fadeInUp 0.6s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    @@keyframes fadeInUp {
        to

    {
        opacity: 1;
        transform: translateY(0);
    }

    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 col-sm-10 fade-in-up">

            <div class="card card-registration p-4 p-md-5">
                <div class="card-body">

                    <div class="text-center mb-5">
                        <a href="/" class="brand-logo">
                            Gift<span>Ride</span>
                        </a>
                        <p class="text-muted fw-bold small text-uppercase ls-1">Започни своето приключение</p>
                    </div>

                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 rounded-3 mb-4" role="alert" style="display:none;"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating mb-3 position-relative">
                                    <input asp-for="Input.FirstName" class="form-control" aria-required="true" placeholder="First Name" />
                                    <label asp-for="Input.FirstName">Име</label>
                                    <i class="bi bi-person input-icon"></i>
                                    <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3 position-relative">
                                    <input asp-for="Input.LastName" class="form-control" aria-required="true" placeholder="Last Name" />
                                    <label asp-for="Input.LastName">Фамилия</label>
                                    <i class="bi bi-person input-icon"></i>
                                    <span asp-validation-for="Input.LastName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="Input.Username" class="form-control" autocomplete="username" aria-required="true" placeholder="Username" />
                            <label asp-for="Input.Username">Потребителско име</label>
                            <i class="bi bi-person-badge input-icon"></i>
                            <span asp-validation-for="Input.Username" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="Input.Address" class="form-control" placeholder="Address" />
                            <label asp-for="Input.Address">Адрес</label>
                            <i class="bi bi-geo-alt input-icon"></i>
                            <span asp-validation-for="Input.Address" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email">Имейл адрес</label>
                            <i class="bi bi-envelope input-icon"></i>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="PhoneNumber" />
                            <label asp-for="Input.PhoneNumber">Телефон</label>
                            <i class="bi bi-telephone input-icon"></i>
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password">Парола</label>
                            <i class="bi bi-lock input-icon"></i>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 position-relative">
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.ConfirmPassword">Потвърди паролата</label>
                            <i class="bi bi-lock-fill input-icon"></i>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-4 ms-2">
                            <input class="form-check-input" type="checkbox" value="" id="invalidCheck" required style="cursor: pointer;">
                            <label class="form-check-label text-muted small" for="invalidCheck" style="cursor: pointer;">
                                Съгласен съм с <a href="#" class="text-decoration-none fw-bold" style="color: var(--gift-blue);">Общите условия</a>
                            </label>
                        </div>

                        <div class="d-grid">
                            <button id="registerSubmit" type="submit" class="btn btn-register rounded-pill">
                                Създай акаунт <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>

                        <div class="text-center mt-4">
                            <span class="text-muted small">Вече си част от отбора?</span>
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none login-link ms-1">Влез тук</a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}