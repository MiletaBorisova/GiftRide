<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GiftRide</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GiftRide.styles.css" asp-append-version="true" />

    <style>
        :root {
            --gift-teal: #2dd4bf;
            --gift-blue: #0ea5e9;
            --admin-dark: #334155;
            --ride-orange: #f43f5e;
            
        }

        
        .navbar {
            padding: 0.8rem 2rem;
            background-color: #fff !important;
        }

        .navbar-brand img {
            
            height: 90px !important;
            max-height: none !important;
            width: auto; 
            transition: transform 0.3s ease;
        }

        .nav-link {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
            color: #333 !important;
            transition: color 0.3s;
        }

            .nav-link:hover {
                color: var(--gift-blue) !important;
            }

        .navbar-brand img {
            max-height: 50px;
            width: auto;
        }

        
        .nav-icon-wrapper {
            position: relative;
            display: inline-block;
            margin-left: 15px;
            color: #333;
            font-size: 1.4rem;
            transition: transform 0.2s;
        }

            .nav-icon-wrapper:hover {
                transform: scale(1.1);
                color: var(--ride-orange);
            }

        .badge-count {
            position: absolute;
            top: -5px;
            right: -10px;
            background-color: var(--ride-orange);
            color: white;
            border-radius: 50%;
            padding: 2px 6px;
            font-size: 0.65rem;
            font-weight: bold;
            border: 2px solid #fff;
        }

        
        .btn-nav-custom {
            border: none;
            color: white !important;
            font-weight: 600;
            padding: 8px 18px;
            border-radius: 30px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        .btn-categories {
            background: linear-gradient(135deg, var(--gift-teal), var(--gift-blue));
        }

        .btn-admin {
            background: linear-gradient(135deg, var(--admin-dark), #1e293b);
        }

        
        .custom-dropdown-menu {
            border: none;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 10px;
        }

        .custom-dropdown-item {
            padding: 8px 15px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
        }

            .custom-dropdown-item:hover {
                background-color: #f8f9fa;
                color: var(--gift-blue);
                padding-left: 20px;
            }


        /*Chatbot styling*/

        #chat-widget-container {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 9999;
            font-family: 'Montserrat', sans-serif;
        }

       
        #chat-toggle-btn {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #f43f5e, #f97316); /* Твоят оранжев градиент */
            color: white;
            border: none;
            font-size: 24px;
            box-shadow: 0 4px 15px rgba(244, 63, 94, 0.4);
            cursor: pointer;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            #chat-toggle-btn:hover {
                transform: scale(1.1);
            }

        
        #chat-window {
            width: 350px;
            height: 450px;
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            position: absolute;
            bottom: 80px;
            right: 0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: all 0.3s ease;
            opacity: 1;
            transform: translateY(0);
        }

       
        .chat-hidden {
            display: none !important; 
        }

        
        .chat-header {
            background: linear-gradient(135deg, #2dd4bf, #0ea5e9); 
            color: white;
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-close-chat {
            background: none;
            border: none;
            color: white;
            font-size: 1.2rem;
            cursor: pointer;
        }

        /* Message */
        .chat-body {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            background: #f8fafc;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* Input */
        .chat-footer {
            padding: 10px;
            background: #fff;
            border-top: 1px solid #eee;
            display: flex;
            gap: 10px;
        }

        #user-input {
            flex: 1;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            padding: 8px 15px;
            outline: none;
            font-size: 0.9rem;
        }

        #send-btn {
            background: #f43f5e;
            color: white;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
        }

       
        .bot-msg {
            align-self: flex-start;
            background: #e0f2fe;
            color: #334155;
            padding: 10px 15px;
            border-radius: 15px 15px 15px 0;
            font-size: 0.9rem;
            max-width: 80%;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .user-msg {
            align-self: flex-end;
            background: #f43f5e;
            color: white;
            padding: 10px 15px;
            border-radius: 15px 15px 0 15px;
            font-size: 0.9rem;
            max-width: 80%;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto align-items-center">
                        <a class="navbar-brand ms-4 me-0" asp-controller="Home" asp-action="Index">
                            <img src="~/pictures/GiftRideLogo.svg" alt="GiftRide Logo" />

                        </a>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contacts">Контакти</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Преживявания</a>
                        </li>



                        @if (this.User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Order" asp-action="MyOrders">Моите поръчки</a>
                            </li>
                        }
                        

                        <li class="nav-item dropdown ms-2">
                            <button class="btn btn-nav-custom btn-categories dropdown-toggle" type="button" data-bs-toggle="dropdown">
                               Категории
                            </button>
                            <ul class="dropdown-menu custom-dropdown-menu">
                                <li><a class="dropdown-item custom-dropdown-item" asp-controller="Product" asp-action="Index" asp-route-searchStringCategoryName="Въздушни">Въздушни</a></li>
                                <li><a class="dropdown-item custom-dropdown-item" asp-controller="Product" asp-action="Index" asp-route-searchStringCategoryName="Водни">Водни</a></li>
                                <li><a class="dropdown-item custom-dropdown-item" asp-controller="Product" asp-action="Index" asp-route-searchStringCategoryName="Зимни">Зимни</a></li>
                                <li><a class="dropdown-item custom-dropdown-item" asp-controller="Product" asp-action="Index" asp-route-searchStringCategoryName="Офроуд и Моторни">Офроуд и Моторни</a></li>
                                <li><a class="dropdown-item custom-dropdown-item" asp-controller="Product" asp-action="Index" asp-route-searchStringCategoryName="Спорт и Природа">Спорт и Природа</a></li>
                            </ul>
                        </li>

                        @if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
                        {
                            <li class="nav-item dropdown ms-2">
                                <button class="btn btn-nav-custom btn-admin dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                   Админ
                                </button>
                                <ul class="dropdown-menu custom-dropdown-menu">
                                    <li><a class="dropdown-item custom-dropdown-item" href="/Client/Index">Клиенти</a></li>
                                    <li><a class="dropdown-item custom-dropdown-item" href="/Order/Index">Поръчки</a></li>
                                    <li><a class="dropdown-item custom-dropdown-item" href="/Statistic/Index">Статистика</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />

                        @if (User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Favorites" asp-action="Index" class="nav-icon-wrapper text-decoration-none">
                                <i class="bi bi-heart"></i>
                                
                            </a>

                            <a asp-controller="Cart" asp-action="Index" class="nav-icon-wrapper text-decoration-none">
                                <i class="bi bi-bag"></i>
                                
                            </a>
                        }

                        
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-3 bg-white border-top shadow-sm">
        <div class="container text-center">
            <span class="text-muted small">
                &copy; 2026 <strong>GiftRide</strong>. Всички права запазени.
                <span class="mx-2">|</span>
                <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-primary fw-bold">
                    Политика за поверителност
                </a>
            </span>
        </div>
    </footer>


    <div id="chat-widget-container">

        <button id="chat-toggle-btn" onclick="toggleChat()">
            <i class="bi bi-chat-dots-fill"></i>
        </button>

        <div id="chat-window" class="chat-hidden">

            <div class="chat-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-robot fs-4"></i>
                    <div>
                        <span class="fw-bold d-block" style="font-size: 0.9rem;">GiftRide Bot</span>
                        <span class="small opacity-75">Online</span>
                    </div>
                </div>
                <button onclick="toggleChat()" class="btn-close-chat"><i class="bi bi-x-lg"></i></button>
            </div>

            <div id="chat-messages" class="chat-body">
                <div class="bot-msg">
                    👋 Здравей! Аз съм AI асистентът на GiftRide. Питай ме за валидност, доставка или всичко, което те интересува!
                </div>
            </div>

            <div class="chat-footer">
                <input type="text" id="user-input" placeholder="Питай нещо..." onkeypress="handleKeyPress(event)">
                <button onclick="sendMessage()" id="send-btn">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>

    </div>


    <script>
        // Отваряне и затваряне на чата
        function toggleChat() {
            var chatWindow = document.getElementById('chat-window');
            if (chatWindow.classList.contains('chat-hidden')) {
                chatWindow.classList.remove('chat-hidden');
                
                setTimeout(() => document.getElementById('user-input').focus(), 100);
            } else {
                chatWindow.classList.add('chat-hidden');
            }
        }

        //Търси Enter
        function handleKeyPress(e) {
            if (e.key === 'Enter') {
                sendMessage();
            }
        }

        // Изпращане на съобщение
        function sendMessage() {
            var inputField = document.getElementById('user-input');
            var message = inputField.value.trim();

            if (message === "") return;

            // Добавя съобщението на потребителя в чата
            addMessage(message, 'user-msg');
            inputField.value = ''; // Чистим полето


            // AJAX ЗАЯВКА КЪМ СЪРВЪРА
            $.ajax({
                type: "POST",
                url: "/Chat/GetResponse", 
                data: { message: message },
                success: function (response) {
                    // Добавяме отговора на бота
                    addMessage(response.reply, 'bot-msg');
                },
                error: function () {
                    addMessage("Опа, нещо се обърка с връзката.", 'bot-msg');
                }
            });
        }

        //Функция за рисуване на балончета
        function addMessage(text, className) {
            var chatBody = document.getElementById('chat-messages');
            var div = document.createElement('div');
            div.className = className;
            div.innerText = text;
            chatBody.appendChild(div);

            // Скролва най-долу
            chatBody.scrollTop = chatBody.scrollHeight;
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>