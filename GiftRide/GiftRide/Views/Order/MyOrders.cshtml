@model IEnumerable<GiftRide.Models.Order.OrderIndexVM>
@using GiftRide.Infrastructure.Data.Entities

@{
    ViewData["Title"] = "Моите Поръчки";
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4">
        <h1 class="fw-bold text-dark me-3">📦 Моите Поръчки</h1>
        <span class="badge bg-light text-dark border rounded-pill">@Model.Count() поръчки</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <h3 class="mt-3">Все още нямате поръчки</h3>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary rounded-pill mt-3 px-4">
                Разгледай приключения
            </a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="py-3 ps-4">Дата</th>
                            <th class="py-3">Продукт</th>
                            <th class="py-3">Снимка</th>
                            <th class="py-3">Количество</th>
                            <th class="py-3">Обща цена</th>

                            <th class="py-3 text-center" style="min-width: 180px;">Резервация</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">
                                    @Html.DisplayFor(modelItem => item.OrderDate)
                                </td>

                                <td>
                                    <span class="fw-bold text-dark d-block" style="font-size: 1.05rem;">
                                        @Html.DisplayFor(modelItem => item.Product)
                                    </span>
                                    @if (item.Discount > 0)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill mt-1">
                                            -@item.Discount% отстъпка
                                        </span>
                                    }
                                </td>

                                <td>
                                    <img src="@Html.DisplayFor(modelItem => item.Picture)"
                                         alt="Product Image"
                                         class="rounded-3 shadow-sm"
                                         style="width: 80px; height: 60px; object-fit: cover;" />
                                </td>

                                <td class="fw-bold text-dark fs-5 ps-4">
                                    @Html.DisplayFor(modelItem => item.Quantity)
                                </td>

                                <td class="fw-bold" style="color: var(--gift-blue);">
                                    @Html.DisplayFor(modelItem => item.Price) €
                                </td>

                                <td class="text-center">

                                    <p class="text-danger">DEBUG: VoucherId = @item.VoucherId</p>

                                    @* СЛУЧАЙ 1: НЯМА РЕЗЕРВАЦИЯ -> БУТОН *@
                                    @if (item.Status == ReservationStatus.None)
                                    {
                                        <a asp-controller="Reservation" asp-action="Create" asp-route-id="@item.VoucherId"
                                           class="btn btn-sm text-white fw-bold rounded-pill px-3 shadow-sm btn-hover-effect"
                                           style="background: linear-gradient(135deg, #2dd4bf, #0ea5e9); border: none;">
                                            <i class="bi bi-calendar-plus me-1"></i> Резервирай
                                        </a>


                                    }
                                   

                                    @* СЛУЧАЙ 2: ЧАКАЩА -> ЖЪЛТО *@
                                    else if (item.Status == ReservationStatus.Pending)
                                    {
                                        <div class="d-inline-block">
                                            <span class="badge bg-warning text-dark rounded-pill border border-warning">
                                                <i class="bi bi-hourglass-split"></i> Чака одобрение
                                            </span>
                                            @if (item.ReservationDate.HasValue)
                                            {
                                                <div class="small text-muted mt-1 fw-bold">
                                                    за @item.ReservationDate.Value.ToString("dd.MM.yyyy")
                                                </div>
                                            }
                                        </div>
                                    }

                                    @* СЛУЧАЙ 3: ПОТВЪРДЕНА -> ЗЕЛЕНО *@
                                    else if (item.Status == ReservationStatus.Approved)
                                    {
                                        <div class="d-inline-block">
                                            <span class="badge bg-success rounded-pill border border-success">
                                                <i class="bi bi-check-circle-fill"></i> Потвърдена
                                            </span>
                                            @if (item.ReservationDate.HasValue)
                                            {
                                                <div class="small text-success fw-bold mt-1">
                                                    @item.ReservationDate.Value.ToString("dd.MM.yyyy")
                                                </div>
                                            }
                                        </div>
                                    }

                                    @* СЛУЧАЙ 4: ОТКАЗАНА -> ЧЕРВЕНО + БУТОН *@
                                    else if (item.Status == ReservationStatus.Rejected)
                                    {
                                        <div class="d-inline-block">
                                            <span class="badge bg-danger rounded-pill mb-1">
                                                <i class="bi bi-x-circle"></i> Отказана
                                            </span>
                                            <br />
                                            <a asp-controller="Reservation" asp-action="Create" asp-route-id="@item.VoucherId"
                                               class="btn btn-outline-danger btn-sm rounded-pill py-0 px-2"
                                               style="font-size: 0.75rem;">
                                                Опитай пак
                                            </a>
                                        </div>
                                    }

                                  
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    /* Малък ефект при минаване с мишката върху бутона */
    .btn-hover-effect:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(14, 165, 233, 0.3) !important;
    }
</style>