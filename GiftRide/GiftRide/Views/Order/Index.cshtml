@using GiftRide.Infrastructure.Data.Entities
@model IEnumerable<GiftRide.Models.Order.OrderIndexVM>

@{
    ViewData["Title"] = "Index";
}

<h1>All Orders</h1>

<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>@Html.DisplayNameFor(model => model.OrderDate)</th>
            <th>@Html.DisplayNameFor(model => model.User)</th>
            <th>@Html.DisplayNameFor(model => model.Product)</th>
            <th>@Html.DisplayNameFor(model => model.Picture)</th>
            <th>@Html.DisplayNameFor(model => model.Quantity)</th>
            <th>@Html.DisplayNameFor(model => model.Price)</th>
            <th>@Html.DisplayNameFor(model => model.Discount)</th>
            <th>@Html.DisplayNameFor(model => model.TotalPrice)</th>

            <th class="text-center" style="width: 200px;">Reservation Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.OrderDate)</td>
                <td>@Html.DisplayFor(modelItem => item.User)</td>
                <td>@Html.DisplayFor(modelItem => item.Product)</td>
                <td>
                    <img src="@Html.DisplayFor(modelItem => item.Picture)"
                         alt="Image" width="80" class="rounded shadow-sm" />
                </td>
                <td>@Html.DisplayFor(modelItem => item.Quantity)</td>
                <td>@Html.DisplayFor(modelItem => item.Price)</td>
                <td>@Html.DisplayFor(modelItem => item.Discount)</td>
                <td class="fw-bold">@Html.DisplayFor(modelItem => item.TotalPrice)</td>

                <td class="text-center">
                    @if (item.Status == ReservationStatus.None)
                    {
                        @* Случай 1: Няма резервация *@
                        <span class="badge bg-secondary rounded-pill">No Reservation</span>
                    }
                    else
                    {
                        @* Случай 2: Има резервация - показваме дата и опции *@
                        <div class="mb-2 small fw-bold text-muted">
                            📅 @(item.ReservationDate.HasValue? item.ReservationDate.Value.ToString("dd.MM.yyyy") : "-")
                        </div>

                        <form asp-controller="Reservation" asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="voucherId" value="@item.VoucherId" />

                            <select name="statusId" class="form-select form-select-sm border-0 shadow-sm fw-bold
                                            @(item.Status == ReservationStatus.Pending ? "bg-warning bg-opacity-25 text-warning" :
                                                                                          item.Status == ReservationStatus.Approved ? "bg-success bg-opacity-25 text-success" :
                                                                                          "bg-danger bg-opacity-25 text-danger")"
                            onchange="this.form.submit()"
                            style="cursor: pointer;">

                                <option value="1" selected="@(item.Status == ReservationStatus.Pending)">⏳ Pending</option>
                                <option value="2" selected="@(item.Status == ReservationStatus.Approved)">✅ Approve</option>
                                <option value="3" selected="@(item.Status == ReservationStatus.Rejected)">❌ Reject</option>
                            </select>
                        </form>
                                }
                </td>
            </tr>
        }
    </tbody>
</table>