@using GiftRide.Infrastructure.Data.Entities
@model IEnumerable<GiftRide.Models.Order.OrderIndexVM>

@{
    ViewData["Title"] = "Index";
}

<style>
    body {
        font-family: 'Montserrat', sans-serif;
        background-color: #f8fafc;
        /* Твоят фон (Mesh Gradient) */
        background-image: radial-gradient(at 0% 0%, rgba(45, 212, 191, 0.15) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.15) 0px, transparent 50%);
        background-attachment: fixed;
        background-size: cover;
    }

    /* Стил за самата таблица */
    .table-modern thead th {
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #64748b; /* Muted text */
        font-weight: 700;
        border-bottom: 2px solid #f1f5f9;
        padding: 1.2rem 1rem;
        background-color: #ffffff;
    }

    .table-modern tbody td {
        background-color: #ffffff;
        border-bottom: 1px solid #f1f5f9;
        padding: 1rem 1rem;
        font-size: 0.95rem;
        vertical-align: middle;
    }

    .table-modern tbody tr:last-child td {
        border-bottom: none;
    }

    /* Ефект при минаване с мишката */
    .table-modern tbody tr:hover td {
        background-color: #f8fafc;
    }
</style>

<div class="container-fluid py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark m-0">Всички поръчки</h2>
        <span class="badge bg-white text-dark shadow-sm border rounded-pill px-3 py-2">
            Общо: @Model.Count()
        </span>
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0 w-100 text-nowrap">
                    <thead>
                        <tr>
                            <th>Дата</th>
                            <th>Клиент</th>
                            <th>Продукт</th>
                            <th>Снимка</th>
                            <th class="text-center">Кол.</th>
                            <th>Ед. Цена</th>
                            <th class="text-center">Отстъпка</th>
                            <th>Общо</th>
                            <th class="text-center" style="min-width: 220px;">Статус Резервация</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted fw-bold">
                                    @Html.DisplayFor(modelItem => item.OrderDate)
                                </td>

                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle p-2 me-2 text-primary">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <span class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.User)</span>
                                    </div>
                                </td>

                                <td>@Html.DisplayFor(modelItem => item.Product)</td>

                                <td>
                                    <img src="@Html.DisplayFor(modelItem => item.Picture)"
                                         alt="Product"
                                         class="rounded-3 shadow-sm object-fit-cover"
                                         width="60" height="60" />
                                </td>

                                <td class="text-center fw-bold text-secondary">
                                    @Html.DisplayFor(modelItem => item.Quantity)
                                </td>

                                <td class="text-muted">
                                    @Html.DisplayFor(modelItem => item.Price)€
                                </td>

                                <td class="text-center">
                                    @if (item.Discount > 0)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill">
                                            -@Html.DisplayFor(modelItem => item.Discount)%
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>

                                <td class="fw-bold text-primary fs-6">
                                    @Html.DisplayFor(modelItem => item.TotalPrice)€
                                </td>

                                <td class="text-center">
                                    @if (item.Status == ReservationStatus.None)
                                    {
                                        <span class="badge bg-light text-secondary border rounded-pill px-3 py-2 fw-normal">
                                            Няма резервация
                                        </span>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-column gap-2">
                                            <small class="text-muted fw-bold">
                                                📅 @(item.ReservationDate.HasValue? item.ReservationDate.Value.ToString("dd.MM.yyyy") : "-")
                                            </small>

                                            <form asp-controller="Reservation" asp-action="UpdateStatus" method="post">
                                                <input type="hidden" name="voucherId" value="@item.VoucherId" />

                                                <select name="statusId" class="form-select form-select-sm border-0 shadow-sm fw-bold text-center py-2
                                                                @(item.Status == ReservationStatus.Pending ? "bg-warning bg-opacity-10 text-warning ring-warning" :
                                                                                                                                  item.Status == ReservationStatus.Approved ? "bg-success bg-opacity-10 text-success ring-success" :
                                                                                                                                  "bg-danger bg-opacity-10 text-danger ring-danger")"
                                                onchange="this.form.submit()"
                                                style="cursor: pointer; border-radius: 8px;">

                                                    <option value="1" selected="@(item.Status == ReservationStatus.Pending)">⏳ Чакаща</option>
                                                    <option value="2" selected="@(item.Status == ReservationStatus.Approved)">✅ Одобрена</option>
                                                    <option value="3" selected="@(item.Status == ReservationStatus.Rejected)">❌ Отказана</option>
                                                </select>
                                            </form>
                                        </div>
                                                                }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>