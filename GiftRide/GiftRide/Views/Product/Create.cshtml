@model GiftRide.Models.Product.ProductCreateVM
@{
    ViewData["Title"] = "Създай Продукт";
}

<style>
    body {
        font-family: 'Montserrat', sans-serif;
        background-color: #f8fafc;
        background-image: radial-gradient(at 0% 0%, rgba(45, 212, 191, 0.15) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.15) 0px, transparent 50%);
        background-attachment: fixed;
        background-size: cover;
    }

    .form-floating > .form-control,
    .form-floating > .form-select {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
    }

        .form-floating > .form-control:focus,
        .form-floating > .form-select:focus {
            border-color: #2dd4bf;
            box-shadow: 0 0 0 4px rgba(45, 212, 191, 0.1);
        }

    .card-modern {
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        border: none;
    }

    .input-group-text {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-right: none;
        border-radius: 12px 0 0 12px;
        color: #64748b;
    }

    
    .input-group > .form-floating > .form-control {
        border-radius: 0 12px 12px 0;
        border-left: none;
    }

    .btn-create {
        background: linear-gradient(135deg, #f43f5e, #f97316);
        border: none;
        color: white;
        font-weight: 700;
        padding: 12px;
        transition: transform 0.2s;
    }

        .btn-create:hover {
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 10px 20px rgba(244, 63, 94, 0.3);
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold m-0 text-dark">Нов Продукт</h2>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-left me-1"></i> Назад
                </a>
            </div>

            <div class="card card-modern p-4 p-md-5">
                <div class="card-body">

                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm border-0 rounded-3 mb-4"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-tag-fill"></i></span>
                                    <div class="form-floating">
                                        <input asp-for="ProductName" class="form-control" placeholder="Name" />
                                        <label asp-for="ProductName">Име на продукта</label>
                                    </div>
                                </div>
                                <span asp-validation-for="ProductName" class="text-danger small ms-2"></span>
                            </div>

                            <div class="col-12">
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-image"></i></span>
                                    <div class="form-floating">
                                        <input asp-for="Picture" class="form-control" placeholder="URL" />
                                        <label asp-for="Picture">URL на снимка</label>
                                    </div>
                                </div>
                                <span asp-validation-for="Picture" class="text-danger small ms-2"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="CategoryId" class="form-select">
                                        @foreach (var category in Model.Categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    </select>
                                    <label asp-for="CategoryId">Категория</label>
                                </div>
                                <span asp-validation-for="CategoryId" class="text-danger small ms-2"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="ValidityId" class="form-select">
                                        @foreach (var validity in Model.Validities)
                                        {
                                            <option value="@validity.Id">@validity.Name</option>
                                        }
                                    </select>
                                    <label asp-for="ValidityId">Валидност</label>
                                </div>
                                <span asp-validation-for="ValidityId" class="text-danger small ms-2"></span>
                            </div>

                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="Description" class="form-control" placeholder="Desc" style="height: 120px"></textarea>
                                    <label asp-for="Description">Описание</label>
                                </div>
                                <span asp-validation-for="Description" class="text-danger small ms-2"></span>
                            </div>

                            <div class="row g-3">

                                <div class="col-md-4">
                                    <div class="input-group">
                                        <span class="input-group-text">€</span>
                                        <div class="form-floating">
                                            <input asp-for="Price" class="form-control" placeholder="0.00" />
                                            <label asp-for="Price">Цена</label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small ms-2"></span>
                                </div>

                                <div class="col-md-4">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-box-seam"></i></span>
                                        <div class="form-floating">
                                            <input asp-for="Quantity" class="form-control" placeholder="0" />
                                            <label asp-for="Quantity">Количество</label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="Quantity" class="text-danger small ms-2"></span>
                                </div>

                                <div class="col-md-4">
                                    <div class="input-group">
                                        <span class="input-group-text">%</span>
                                        <div class="form-floating">
                                            <input asp-for="Discount" class="form-control" placeholder="0" />
                                            <label asp-for="Discount">Отстъпка</label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="Discount" class="text-danger small ms-2"></span>
                                </div>

                            </div>

                        </div>

                        <div class="d-grid mt-5">
                            <button type="submit" class="btn btn-create rounded-pill shadow-sm text-uppercase ls-1">
                                <i class="bi bi-plus-circle me-2"></i> Създай Продукт
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}