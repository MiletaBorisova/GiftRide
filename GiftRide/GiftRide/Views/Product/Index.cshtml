@model IEnumerable<GiftRide.Models.Product.ProductIndexVM>

@{
    ViewData["Title"] = "Продукти";
}

<div class="container my-5">
    <h1 class="mb-4">Products</h1>

@if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
{
        <a asp-action="Create" class="btn btn-primary mb-4">Create New</a>
}

<div class="container my-5">
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden product-card">

                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                        <div class="ratio ratio-4x3">
                            <img src="@item.Picture"
                                 class="card-img-top object-fit-cover"
                                 alt="@item.ProductName">
                        </div>
                    </a>

                    <div class="card-body d-flex flex-column">

                        
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                            <h6 class="card-title fw-bold mb-2 text-truncate-2" style="min-height: 2.5em;">
                                @item.ProductName
                            </h6>
                        </a>

                        
                        <div class="mb-3">
                            <span class="text-muted small">Цена:</span>

                            <div class="mt-1">
                                @if (item.Discount > 0)
                                {
                                    
                                    <span class="text-muted text-decoration-line-through me-2 small">
                                        @item.Price.ToString("0.00") €
                                    </span>                                   
                                    <span class="fw-bold text-danger fs-5">
                                        
                                        @((item.Price * (1 - item.Discount / 100m)).ToString("0.00")) €
                                    </span>                                   
                                    <span class="badge bg-danger ms-2">
                                        -@item.Discount.ToString("0")%
                                    </span>
                                }
                                else
                                {
                                   
                                    <span class="fw-bold fs-5">
                                        @item.Price.ToString("0.00") €
                                    </span>
                                }
                            </div>
                        </div>

                        
                        <div class="mt-auto d-grid gap-2">

                           
                            <div class="d-flex gap-2">
                                <a asp-controller="Cart" asp-action="Add" asp-route-productId="@item.Id"
                                   class="btn btn-outline-primary flex-grow-1" title="Добави в количка">
                                    <i class="bi bi-cart-plus"></i> Добави в количка
                                </a>

                                <a asp-controller="Favorites" asp-action="Add" asp-route-productId="@item.Id"
                                   class="btn btn-outline-danger" title="Добави в любими">
                                    <i class="bi bi-heart"></i>
                                </a>
                            </div>

                            
                            <a asp-controller="Order" asp-action="Create" asp-route-id="@item.Id"
                               class="btn btn-primary fw-bold">
                                Поръчай сега
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    body {
        font-family: 'Montserrat', sans-serif;
        /* Основен цвят - много светло сиво-синьо */
        background-color: #f8fafc;
        /* Модерни цветни петна (Mesh Gradient) */
        background-image: radial-gradient(at 0% 0%, rgba(45, 212, 191, 0.15) 0px, transparent 50%), /* Teal горе ляво */
        radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.15) 0px, transparent 50%); /* Orange долу дясно */
        background-attachment: fixed; /* Фонът стои неподвижно при скрол */
        background-size: cover;
    }
    .product-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .object-fit-cover {
        object-fit: cover;
    }
</style>



