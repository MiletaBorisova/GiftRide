@model IEnumerable<GiftRide.Models.Client.ClientIndexVM>

@{
    ViewData["Title"] = "Index";
}

<style>
    body {
        font-family: 'Montserrat', sans-serif;
        background-color: #f8fafc;
        background-image: radial-gradient(at 0% 0%, rgba(45, 212, 191, 0.15) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.15) 0px, transparent 50%);
        background-attachment: fixed;
        background-size: cover;
    }

    
    .table-modern thead th {
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #64748b;
        font-weight: 700;
        border-bottom: 2px solid #f1f5f9;
        padding: 1.2rem 1rem;
        background-color: #ffffff;
    }

    .table-modern tbody td {
        background-color: #ffffff;
        border-bottom: 1px solid #f1f5f9;
        padding: 1rem 1rem;
        font-size: 0.95rem;
        vertical-align: middle;
    }

    .table-modern tbody tr:last-child td {
        border-bottom: none;
    }

    .table-modern tbody tr:hover td {
        background-color: #f8fafc;
    }
</style>

<div class="container-fluid py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark m-0">Clients</h2>
        <span class="badge bg-white text-dark shadow-sm border rounded-pill px-3 py-2">
            Total: @Model.Count()
        </span>
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0 w-100 text-nowrap">
                    <thead>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.UserName)</th>
                            <th>@Html.DisplayNameFor(model => model.FirstName)</th>
                            <th>@Html.DisplayNameFor(model => model.LastName)</th>
                            <th>@Html.DisplayNameFor(model => model.Address)</th>
                            <th>@Html.DisplayNameFor(model => model.Email)</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle p-2 me-2 text-primary">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <span class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.UserName)</span>
                                    </div>
                                </td>
                                <td>@Html.DisplayFor(modelItem => item.FirstName)</td>
                                <td>@Html.DisplayFor(modelItem => item.LastName)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Address))
                                    {
                                        <span class="text-muted"><i class="bi bi-geo-alt me-1"></i>@Html.DisplayFor(modelItem => item.Address)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <a href="mailto:@item.Email" class="text-decoration-none text-primary">
                                        @Html.DisplayFor(modelItem => item.Email)
                                    </a>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm">
                                        <i class="bi bi-trash3"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>