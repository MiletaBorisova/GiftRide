@{
    ViewData["Title"] = "Не може да се изтрие потребител";
}

<style>
    body {
        font-family: 'Montserrat', sans-serif;
        background-color: #f8fafc;
        background-image: radial-gradient(at 0% 0%, rgba(45, 212, 191, 0.15) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.15) 0px, transparent 50%);
        background-attachment: fixed;
        background-size: cover;
    }

    .card-denied {
        border: none;
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        background: #ffffff;
        text-align: center;
        padding: 3rem 2rem;
    }


    .icon-circle-danger {
        width: 100px;
        height: 100px;
        background-color: #fee2e2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem auto;
        animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
    }

        .icon-circle-danger i {
            font-size: 3.5rem;
            color: #ef4444;
        }


    .btn-back {
        background: linear-gradient(135deg, #f43f5e, #f97316);
        border: none;
        color: white;
        font-weight: 700;
        padding: 12px 30px;
        border-radius: 50px;
        transition: transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
        display: inline-block;
        margin-top: 1rem;
    }

        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(244, 63, 94, 0.3);
            color: white;
        }


    @@keyframes shake {
        10%, 90% {
            transform: translate3d(-1px, 0, 0);
        }

        20%, 80% {
            transform: translate3d(2px, 0, 0);
        }

        30%, 50%, 70% {
            transform: translate3d(-4px, 0, 0);
        }

        40%, 60% {
            transform: translate3d(4px, 0, 0);
        }
    }
</style>

<div class="container py-5" style="min-height: 80vh; display: flex; align-items: center; justify-content: center;">
    <div class="col-md-6 col-lg-5">

        <div class="card card-denied">

            <div class="icon-circle-danger">
                <i class="bi bi-cart-x"></i>
            </div>

            <h2 class="fw-bold text-dark mb-3">Потебителят не може да бъде изтрит.</h2>

            <p class="text-muted mb-4 fs-5">
                Не може да изтривате потребител с направени поръчки.
            </p>

            <a asp-controller="Product" asp-action="Index" class="btn btn-back shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Обратно към продуктите
            </a>

        </div>

    </div>
</div>