@{
    ViewData["Title"] = "Контакти";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    :root {
        --gift-teal: #2dd4bf;
        --gift-blue: #0ea5e9;
        --ride-orange: #f43f5e;
        --bg-light: #f8fafc;
    }

    body {
        font-family: 'Montserrat', sans-serif;
        background-color: #f8fafc;
        background-image: radial-gradient(at 0% 0%, rgba(45, 212, 191, 0.15) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.15) 0px, transparent 50%);
        background-attachment: fixed;
        background-size: cover;
    }

    .contact-wrapper {
        padding: 60px 0;
        position: relative;
        overflow: hidden;
        min-height: 80vh;
    }

    .hero-header h1 {
        font-family: 'Montserrat', sans-serif;
        font-weight: 800;
        font-size: 3.5rem;
        letter-spacing: -1px;
        background: linear-gradient(135deg, #333 0%, var(--gift-teal) 40%, var(--ride-orange) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 10px;
        line-height: 1.2;
    }

    .hero-line {
        width: 100px;
        height: 6px;
        background: linear-gradient(to right, var(--gift-teal), var(--ride-orange));
        margin: 20px auto 30px auto;
        border-radius: 10px;
    }

    .hero-text {
        font-family: 'Open Sans', sans-serif;
        color: #555;
        font-size: 1.2rem;
        font-weight: 500;
        line-height: 1.8;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-box {
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
    }

    .delay-1 {
        animation-delay: 0.1s;
    }

    .delay-2 {
        animation-delay: 0.2s;
    }

    .delay-3 {
        animation-delay: 0.3s;
    }

    .info-card {
        text-align: center;
        padding: 30px 20px;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(5px);
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.5);
        height: 100%;
    }

        .info-card:hover {
            background: white;
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            transform: translateY(-5px);
        }

    .icon-circle {
        width: 80px;
        height: 80px;
        margin: 0 auto 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
        background: linear-gradient(135deg, var(--gift-teal), var(--gift-blue));
        box-shadow: 0 10px 20px rgba(45, 212, 191, 0.4);
    }

    .info-title {
        font-weight: 800;
        color: #334155;
        margin-bottom: 10px;
        text-transform: uppercase;
        font-size: 1rem;
        letter-spacing: 1px;
    }

    .info-text, .info-text a {
        color: #64748b;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.3s;
        font-size: 1.1rem;
    }

        .info-text a:hover {
            color: var(--ride-orange);
        }
</style>

<div class="contact-wrapper">
    <div class="container">

       
        <div class="text-center mb-5 animate-box hero-header">
            <h1>Свържете се с нас</h1>
            <div class="hero-line"></div>
            <p class="hero-text text-muted">
                Имате въпроси за нашите продукти или поръчка?<br>
                Екипът на <span style="color: var(--gift-teal); font-weight: bold;">Gift</span><span style="color: var(--ride-orange); font-weight: bold;">Ride</span> е тук, за да помогне!
            </p>
        </div>

     
        <div class="row g-4 justify-content-center">

            <div class="col-md-4 animate-box delay-1">
                <div class="info-card">
                    <div class="icon-circle">
                        <i class="bi bi-envelope-fill"></i>
                    </div>
                    <div class="info-title">Имейл</div>
                    <div class="info-text">
                        <a href="mailto:contact@giftride.bg">contact@giftride.bg</a><br>
                        <span class="small text-muted" style="font-size: 0.9rem;">Отговаряме до 24ч.</span>
                    </div>
                </div>
            </div>

            <div class="col-md-4 animate-box delay-2">
                <div class="info-card">
                    <div class="icon-circle">
                        <i class="bi bi-telephone-fill"></i>
                    </div>
                    <div class="info-title">Телефон / Viber</div>
                    <div class="info-text">
                        <a href="tel:+359888123456">+359 888 123 456</a><br>
                        <span class="small text-muted" style="font-size: 0.9rem;">Пон - Пет: 09:00 - 18:00</span>
                    </div>
                </div>
            </div>

            <div class="col-md-4 animate-box delay-3">
                <div class="info-card">
                    <div class="icon-circle">
                        <i class="bi bi-geo-alt-fill"></i>
                    </div>
                    <div class="info-title">Офис</div>
                    <div class="info-text">
                        гр. София, бул. България 1<br>
                       
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>