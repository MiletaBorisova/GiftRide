@using GiftRide.Models
@using GiftRide.Models.Contact
@model ContactFormVM
@{
    ViewData["Title"] = "Контакти";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
   
    :root {
        --gift-teal: #2dd4bf; 
        --gift-blue: #0ea5e9; 
        --ride-orange: #f43f5e;
        --ride-yellow: #fbbf24; 
        --bg-light: #f8fafc;
    }

    body {
        font-family: 'Montserrat', sans-serif;
        /* Основен цвят - много светло сиво-синьо */
        background-color: #f8fafc;
        /* Модерни цветни петна (Mesh Gradient) */
        background-image: radial-gradient(at 0% 0%, rgba(45, 212, 191, 0.15) 0px, transparent 50%), /* Teal горе ляво */
        radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.15) 0px, transparent 50%); /* Orange долу дясно */
        background-attachment: fixed; /* Фонът стои неподвижно при скрол */
        background-size: cover;
    }

    .contact-wrapper {
        padding: 60px 0;
        position: relative;
        overflow: hidden;
        min-height: 80vh; 
    }

    /* Стил за заглавната секция */
    .hero-header h1 {
        font-family: 'Montserrat', sans-serif; /* Модерен, дебел шрифт */
        font-weight: 800;
        font-size: 3.5rem; /* По-голям размер */
        letter-spacing: -1px; /* Буквите леко сближени за стил */
        /* ГРАДИЕНТЕН ТЕКСТ (Магията!) */
        background: linear-gradient(135deg, #333 0%, var(--gift-teal) 40%, var(--ride-orange) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 10px;
        line-height: 1.2;
    }

    /* Декоративна чертичка отдолу */
    .hero-line {
        width: 100px;
        height: 6px;
        background: linear-gradient(to right, var(--gift-teal), var(--ride-orange));
        margin: 20px auto 30px auto; /* Центрирана */
        border-radius: 10px;
    }

    .hero-text {
        font-family: 'Open Sans', sans-serif;
        color: #555;
        font-size: 1.2rem;
        font-weight: 500;
        line-height: 1.8;
    }

    
    

    /* --- Animations --- */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes float {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-10px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    .animate-box {
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
    }

    .delay-1 {
        animation-delay: 0.1s;
    }

    .delay-2 {
        animation-delay: 0.2s;
    }

    .delay-3 {
        animation-delay: 0.3s;
    }

    .delay-4 {
        animation-delay: 0.5s;
    }

    /* --- Icons --- */
    .info-card {
        text-align: center;
        padding: 30px 20px; 
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(5px);
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.5);
        height: 100%;
    }

        .info-card:hover {
            background: white;
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            transform: translateY(-5px);
        }

    .icon-circle {
        width: 80px;
        height: 80px;
        margin: 0 auto 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
        background: linear-gradient(135deg, var(--gift-teal), var(--gift-blue));
        box-shadow: 0 10px 20px rgba(45, 212, 191, 0.4); 
        animation: float 6s ease-in-out infinite;
    }

    .col-md-4:nth-child(2) .icon-circle {
        animation-duration: 7s;
    }

    .col-md-4:nth-child(3) .icon-circle {
        animation-duration: 5s;
    }

    .info-title {
        font-weight: 800; 
        color: #334155;
        margin-bottom: 10px;
        text-transform: uppercase;
        font-size: 1rem;
        letter-spacing: 1px;
    }

    .info-text, .info-text a {
        color: #64748b;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.3s;
        font-size: 1.1rem; 
    }

        .info-text a:hover {
            color: var(--ride-orange);
        }

    /* --- Form --- */
    .form-section {
        background: white;
        padding: 40px;
        border-radius: 25px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        position: relative;
        z-index: 2;
    }

    .section-title {
        font-weight: 800;
        text-align: center;
        margin-bottom: 30px;
        background: linear-gradient(to right, var(--gift-teal), var(--ride-orange));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .form-control, .form-select {
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px 15px;
        background-color: #f8fafc;
        transition: all 0.3s;
    }

        .form-control:focus, .form-select:focus {
            background-color: white;
            border-color: var(--gift-teal);
            box-shadow: 0 0 0 4px rgba(45, 212, 191, 0.1);
        }

    .form-label {
        font-weight: 600;
        color: #475569;
        font-size: 0.9rem;
        margin-left: 5px;
    }

    /* --- Button --- */
    .btn-gradient {
        background: linear-gradient(135deg, var(--ride-orange), #f97316);
        color: white;
        border: none;
        padding: 15px;
        border-radius: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        width: 100%;
        transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(244, 63, 94, 0.3);
    }

        .btn-gradient:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 25px rgba(244, 63, 94, 0.4);
            background: linear-gradient(135deg, #f97316, var(--ride-orange));
            color: white;
        }
</style>

@*suobshtenie za uspeshno izprateno zapitvane*@ 

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-left: 5px solid var(--gift-teal);">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill fs-4 me-3 text-success"></i>
            <div>
                <h5 class="alert-heading fw-bold mb-1">Успешно изпращане!</h5>
                <p class="mb-0">@TempData["SuccessMessage"]</p>
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@*suobshtenie za greshno popuvlane na formata*@
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-left: 5px solid #dc3545;">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-danger"></i>
            <div>
                <h5 class="alert-heading fw-bold mb-1">Възникна грешка!</h5>
                <p class="mb-0">@TempData["ErrorMessage"]</p>
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="contact-wrapper">
    <div class="container">
        <div class="text-center mb-5 animate-box hero-header">

            <h1>
                Свържете се с нас
            </h1>

            <div class="hero-line"></div>

            <p class="hero-text text-muted">
                Имате въпроси за нашите продукти или поръчка?<br>
                Екипът на <span style="color: var(--gift-teal); font-weight: bold;">Gift</span><span style="color: var(--ride-orange); font-weight: bold;">Ride</span> е тук, за да помогне!
            </p>
        </div>
    </div>

        <div class="row g-4 justify-content-center mb-5">

            <div class="col-md-4 animate-box delay-1">
                <div class="info-card">
                    <div class="icon-circle">
                        <i class="bi bi-envelope-fill"></i>
                    </div>
                    <div class="info-title">Имейл</div>
                    <div class="info-text">
                        <a>info@giftride.bg</a><br>
                        <span class="small text-muted" style="font-size: 0.9rem;">Отговаряме до 24ч.</span>
                    </div>
                </div>
            </div>

            <div class="col-md-4 animate-box delay-2">
                <div class="info-card">
                    <div class="icon-circle">
                        <i class="bi bi-telephone-fill"></i>
                    </div>
                    <div class="info-title">Телефон / Viber</div>
                    <div class="info-text">
                        <a>+359 888 123 456</a><br>
                        <span class="small text-muted" style="font-size: 0.9rem;">Пон - Пет: 09:00 - 18:00</span>
                    </div>
                </div>
            </div>

            <div class="col-md-4 animate-box delay-3">
                <div class="info-card">
                    <div class="icon-circle">
                        <i class="bi bi-chat-dots-fill"></i>
                    </div>
                    <div class="info-title">Онлайн чат</div>
                    <div class="info-text">
                        Социални мрежи<br>
                        <span class="small text-muted" style="font-size: 0.9rem;">Пишете ни за бърз отговор</span>
                    </div>
                </div>
            </div>
        </div>

    

    <div class="row justify-content-center animate-box delay-4">
        <div class="col-lg-8">
            <div class="form-section">
                <h2 class="section-title">Изпратете запитване</h2>

                <form asp-action="Contacts" method="post">

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">Вашето име</label>
                            <input asp-for="Name" class="form-control" placeholder="Иван Иванов" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">Телефон за връзка</label>
                            <input asp-for="Phone" class="form-control" placeholder="+359..." />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label asp-for="Email" class="form-label">Имейл адрес</label>
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mt-3">
                        <label asp-for="Subject" class="form-label">Тема на запитването</label>
                        <select asp-for="Subject" class="form-select">
                            <option value="">Изберете тема...</option>
                            <option value="order">Въпрос за поръчка</option>
                            <option value="product">Информация за продукт</option>
                            <option value="partnership">Партньорство</option>
                            <option value="other">Друго</option>
                        </select>
                    </div>

                    <div class="mt-3 mb-4">
                        <label asp-for="Message" class="form-label">Съобщение</label>
                        <textarea asp-for="Message" class="form-control" rows="5" placeholder="Как можем да ви помогнем?"></textarea>
                        <span asp-validation-for="Message" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-gradient">
                            Изпрати съобщение
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    </div>
</div>